# ==============================================================================
# CIVICMIND AI ENTERPRISE ENVIRONMENT TEMPLATE
# ==============================================================================

# --- Frontend Configurations (Vite) ---
VITE_APP_NAME="CivicMind AI"
VITE_API_BASE_URL="http://localhost:8000/api/v1"

# --- Backend Server Configurations (FastAPI) ---
PORT=8000
HOST="0.0.0.0"
ENVIRONMENT="development" # development, staging, production
DEBUG=true

# --- Database Credentials (PostgreSQL & Redis) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/CivicMind_AI"
REDIS_URL="redis://localhost:6379/0"

# --- Firebase Client Credentials (Authentication) ---
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# --- Google Cloud Platform & Vertex AI (RAG & Agents) ---
GCP_PROJECT_ID=""
GCP_REGION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS=""
GEMINI_API_KEY=""

# --- Security Credentials (JWT & Encryption) ---
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
